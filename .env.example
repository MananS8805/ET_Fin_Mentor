# ET FinMentor Environment Configuration
# Copy this file to .env and fill in your credentials

# REQUIRED: Supabase Configuration (for profile sync and data persistence)
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
# These are safe to expose in the client — protected by Row-Level Security
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxx

# REQUIRED: Gemini API Configuration (for AI-powered features)
# Get this from: https://aistudio.google.com > Get API Key
# ⚠️  For production, move this to a backend server to protect the key
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSyxxx

